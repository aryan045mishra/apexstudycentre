---
interface Props {
  activePage?: string;
}
const { activePage = 'home' } = Astro.props;

const links = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/class-9', label: 'Classes', key: 'classes' },
  { href: '/about', label: 'About', key: 'about' },
  { href: '/#contact', label: 'Contact', key: 'contact' },
];

const classLinks = [
  { href: '/class-9', label: 'Class 9' },
  { href: '/class-10', label: 'Class 10' },
  { href: '/class-11', label: 'Class 11' },
  { href: '/class-12', label: 'Class 12' },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: rgba(245, 240, 232, 0.0); backdrop-filter: blur(0px);"
>
  <style>
    #navbar.scrolled {
      background: rgba(245, 240, 232, 0.88) !important;
      backdrop-filter: blur(16px) !important;
      border-bottom: 1px solid rgba(124, 154, 126, 0.18);
      box-shadow: 0 2px 24px rgba(44, 44, 44, 0.06);
    }
    .dropdown { display: none; }
    .dropdown-parent:hover .dropdown { display: block; }
  </style>

<nav class="max-w-7xl mx-auto px-6 lg:px-10 h-18 flex items-center justify-between py-4">
  <a href="/" class="flex items-center gap-2 group">
      
      <img src="/favicon.svg" alt="Apex Study Centre Logo" class="w-12 h-12" />
      
    <span class="font-playfair text-xl font-700 text-charcoal tracking-tight group-hover:text-sage-dark transition-colors">
      Apex Study Centre
    </span>
  </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-8">
      <a
        href="/"
        class={`nav-link font-grotesk text-sm font-500 transition-colors ${activePage === 'home' ? 'text-sage-dark active' : 'text-charcoal-light hover:text-charcoal'}`}
      >
        Home
      </a>

      <!-- Classes Dropdown -->
      <div class="dropdown-parent relative">
        <a
          href="/class-9"
          class={`nav-link font-grotesk text-sm font-500 transition-colors flex items-center gap-1 ${['class-9','class-10','class-11','class-12'].includes(activePage) ? 'text-sage-dark active' : 'text-charcoal-light hover:text-charcoal'}`}
        >
          Classes
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </a>
        <div class="dropdown absolute top-full left-1/2 -translate-x-1/2 mt-3 w-44 bg-white rounded-xl shadow-card-hover border border-cream-dark p-2 z-50">
          {classLinks.map(link => (
            <a
              href={link.href}
              class="block px-4 py-2.5 font-grotesk text-sm text-charcoal-light hover:text-charcoal hover:bg-cream rounded-lg transition-colors"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <a
        href="/#about"
        class={`nav-link font-grotesk text-sm font-500 transition-colors ${activePage === 'about' ? 'text-sage-dark active' : 'text-charcoal-light hover:text-charcoal'}`}
      >
        About
      </a>
      <a
        href="/#contact"
        class={`nav-link font-grotesk text-sm font-500 transition-colors ${activePage === 'contact' ? 'text-sage-dark active' : 'text-charcoal-light hover:text-charcoal'}`}
      >
        Contact
      </a>
    </div>

    <!-- Desktop CTA -->
    <div class="hidden lg:flex items-center gap-3">
      <a
        href="/#contact"
        class="font-grotesk text-sm font-500 text-charcoal border border-charcoal/20 px-5 py-2.5 rounded-full hover:border-charcoal/50 hover:bg-charcoal/5 transition-all duration-200"
      >
        Talk to Us
      </a>
      <a
        href="/#enroll"
        class="font-grotesk text-sm font-600 bg-sage-dark text-white px-5 py-2.5 rounded-full hover:bg-sage transition-all duration-200 shadow-sage hover:shadow-none"
      >
        Enroll Now →
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="menu-btn"
      class="lg:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-cream-dark transition-colors"
      aria-label="Open menu"
    >
      <span class="w-6 h-0.5 bg-charcoal rounded-full"></span>
      <span class="w-4 h-0.5 bg-charcoal rounded-full"></span>
      <span class="w-6 h-0.5 bg-charcoal rounded-full"></span>
    </button>
  </nav>

  <!-- Mobile Full-Screen Menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-cream z-50 flex flex-col"
  >
    <div class="flex items-center justify-between px-6 py-5 border-b border-cream-dark">
      <span class="font-playfair text-xl font-700 text-charcoal">
        Ascend<span class="text-sage-dark">.</span>Academy
      </span>
      <button
        id="close-menu"
        class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-cream-dark transition-colors"
        aria-label="Close menu"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path d="M15 5L5 15M5 5L15 15" stroke="#2C2C2C" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <nav class="flex-1 flex flex-col px-6 pt-8 gap-1">
      <a href="/" class="font-playfair text-3xl font-600 text-charcoal py-3 border-b border-cream-dark hover:text-sage-dark transition-colors">Home</a>
      <div class="py-3 border-b border-cream-dark">
        <p class="font-grotesk text-xs font-600 text-charcoal-muted uppercase tracking-widest mb-3">Classes</p>
        <div class="grid grid-cols-2 gap-2">
          {classLinks.map(link => (
            <a
              href={link.href}
              class="font-playfair text-xl font-500 text-charcoal hover:text-sage-dark transition-colors py-1"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
      <a href="/#about" class="font-playfair text-3xl font-600 text-charcoal py-3 border-b border-cream-dark hover:text-sage-dark transition-colors">About</a>
      <a href="/#contact" class="font-playfair text-3xl font-600 text-charcoal py-3 border-b border-cream-dark hover:text-sage-dark transition-colors">Contact</a>
    </nav>

    <div class="px-6 pb-10 flex flex-col gap-3">
      <a
        href="/#enroll"
        class="font-grotesk font-600 text-center bg-sage-dark text-white py-4 rounded-2xl hover:bg-sage transition-colors text-lg"
      >
        Enroll Now →
      </a>
      <a
        href="/#contact"
        class="font-grotesk font-500 text-center border border-charcoal/20 text-charcoal py-4 rounded-2xl hover:bg-cream-dark transition-colors text-lg"
      >
        Talk to Us
      </a>
    </div>
  </div>
</header>
