---
interface Props {
  heading?: string;
  subtext?: string;
  btnLabel?: string;
  btnHref?: string;
  urgency?: boolean;
}

const {
  heading = 'Your Rank Starts Here — Enroll Today',
  subtext = 'Limited seats available. Join the students already building their future.',
  btnLabel = 'Enroll Now',
  btnHref = '/#enroll',
  urgency = false,
} = Astro.props;
---

<section id="enroll" class="relative overflow-hidden bg-sage-dark py-20 lg:py-28 grain-overlay">
  <!-- Background shapes -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute -top-20 -left-20 w-80 h-80 rounded-full bg-white opacity-5 blur-2xl"></div>
    <div class="absolute -bottom-20 -right-20 w-96 h-96 rounded-full bg-white opacity-5 blur-2xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full border border-white/10"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] rounded-full border border-white/8"></div>
  </div>

  <div class="max-w-4xl mx-auto px-6 lg:px-10 text-center relative z-10">
    {urgency && (
      <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm text-white font-grotesk text-xs font-600 uppercase tracking-widest px-4 py-2 rounded-full mb-6 border border-white/20" data-animate="fade">
        <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
        Seats Filling Fast — Act Now
      </div>
    )}

    <h2 class="font-playfair text-4xl lg:text-6xl font-800 text-white leading-tight mb-5" data-animate>
      {heading}
    </h2>
    <p class="font-dm text-lg text-white/75 max-w-xl mx-auto mb-10" data-animate data-delay="100">
      {subtext}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center" data-animate data-delay="200">
      <a
        href={btnHref}
        class="font-grotesk font-600 text-sage-dark bg-white px-8 py-4 rounded-full text-base hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 inline-flex items-center gap-2"
      >
        {btnLabel}
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href="/#contact"
        class="font-grotesk font-500 text-white border border-white/30 px-8 py-4 rounded-full text-base hover:bg-white/10 transition-all duration-200"
      >
        Talk to an Expert
      </a>
    </div>

    <!-- Trust signals -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-white/60" data-animate data-delay="300">
      <div class="flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <span class="font-grotesk text-xs">No online sessions — 100% offline</span>
      </div>
      <div class="flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <span class="font-grotesk text-xs">Small batch sizes</span>
      </div>
      <div class="flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <span class="font-grotesk text-xs">Expert faculty only</span>
      </div>
      <div class="flex items-center gap-2">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <span class="font-grotesk text-xs">Free trial class available</span>
      </div>
    </div>
  </div>
</section>
