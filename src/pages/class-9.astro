---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubjectCard from '../components/SubjectCard.astro';
import CTABanner from '../components/CTABanner.astro';
---

<BaseLayout
  title="Class 9 Coaching"
  description="Class 9 offline coaching at Ascend Academy. Expert-led Mathematics and Science for CBSE Class 9 students."
  activePage="class-9"
>
  <!-- ── HERO ── -->
  <section class="relative bg-cream pt-32 pb-20 lg:pt-40 lg:pb-28 overflow-hidden grain-overlay">
    <!-- Background blob -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] blob opacity-15 translate-x-1/3 -translate-y-1/3 pointer-events-none"></div>
    <div class="absolute inset-0 bg-dot-grid bg-dot-grid opacity-40 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 mb-8" data-animate="fade">
        <a href="/" class="font-grotesk text-xs text-charcoal-muted hover:text-sage-dark transition-colors">Home</a>
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M4.5 3L7.5 6L4.5 9" stroke="#6B6B6B" stroke-width="1.2" stroke-linecap="round"/></svg>
        <span class="font-grotesk text-xs text-sage-dark font-600">Class 9</span>
      </nav>

      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div>
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 bg-sage-faint border border-sage-pale text-sage-dark font-grotesk text-xs font-600 px-4 py-2 rounded-full mb-5" data-animate="fade">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Offline Coaching Only · Delhi
          </div>

          <h1 class="font-playfair font-900 text-charcoal leading-tight mb-5" style="font-size: clamp(2.4rem, 5vw, 4rem);" data-animate>
            Class 9 —<br/>
            <em class="text-sage-dark not-italic">Build Your Foundation Right</em>
          </h1>

          <p class="font-dm text-lg text-charcoal-muted leading-relaxed mb-8 max-w-lg" data-animate data-delay="100">
            Master Mathematics and Science fundamentals with expert guidance and structured practice. Class 9 is where winners begin — we make sure you start right.
          </p>

          <div class="flex flex-wrap gap-3" data-animate data-delay="200">
            <a
              href="/#contact"
              class="font-grotesk font-600 text-base bg-sage-dark text-white px-7 py-3.5 rounded-full shadow-sage hover:bg-sage transition-all duration-200 inline-flex items-center gap-2"
            >
              Enroll for Class 9 →
            </a>
            <a
              href="/#contact"
              class="font-grotesk font-500 text-base text-charcoal border-2 border-charcoal/20 px-7 py-3.5 rounded-full hover:border-charcoal/50 transition-all duration-200"
            >
              Free Trial Class
            </a>
          </div>
        </div>

        <!-- Right: Summary cards -->
        <div class="grid grid-cols-2 gap-3" data-animate="slide-right" data-delay="200">
          {[
            { emoji: '📐', label: 'Subjects', value: '2 Core Subjects' },
            { emoji: '⏱️', label: 'Duration', value: 'Full Academic Year' },
            { emoji: '👥', label: 'Batch Size', value: '≤ 15 Students' },
            { emoji: '📝', label: 'Tests', value: 'Weekly + Monthly' },
          ].map(card => (
            <div class="bg-white rounded-2xl p-5 shadow-card border border-cream-dark card-lift">
              <div class="text-2xl mb-2">{card.emoji}</div>
              <p class="font-grotesk text-xs text-charcoal-muted uppercase tracking-widest font-500">{card.label}</p>
              <p class="font-playfair font-700 text-lg text-charcoal mt-0.5">{card.value}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── SUBJECTS ── -->
  <section class="bg-cream-dark py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-12" data-animate>
        <span class="font-grotesk text-xs font-600 text-sage-dark uppercase tracking-widest">What We Teach</span>
        <h2 class="font-playfair font-800 text-4xl lg:text-5xl text-charcoal mt-2">Class 9 Subjects</h2>
        <p class="font-dm text-charcoal-muted mt-3 max-w-md mx-auto">Both subjects taught by subject specialists, not generalists.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <SubjectCard
          subject="Mathematics"
          icon="📐"
          color="green"
          chapters={['Number Systems', 'Polynomials', 'Coordinate Geometry', 'Linear Equations', 'Triangles', 'Heron\'s Formula', 'Quadrilaterals', 'Statistics', 'Probability']}
          outcomes={[
            'Solve real-number problems with confidence and speed',
            'Master polynomial operations and factorization',
            'Prove geometric theorems using logical reasoning',
            'Analyze data using mean, median, and mode',
            'Apply coordinate geometry to real-world problems',
          ]}
          delay="0"
        />
        <SubjectCard
          subject="Science"
          icon="🔬"
          color="blue"
          chapters={['Matter in Our Surroundings', 'Is Matter Around Us Pure?', 'Atoms & Molecules', 'Structure of Atom', 'Cell — The Unit of Life', 'Tissues', 'Motion', 'Force & Laws of Motion', 'Gravitation', 'Work, Energy & Power', 'Sound', 'Natural Resources']}
          outcomes={[
            'Understand atomic structure and chemical composition',
            'Explain life processes at the cellular and tissue level',
            'Apply Newton\'s Laws of Motion to solve problems',
            'Describe gravitational force and its universal effects',
            'Analyze wave properties and sound transmission',
          ]}
          delay="150"
        />
      </div>
    </div>
  </section>

  <!-- ── OUR APPROACH ── -->
  <section class="bg-cream py-20 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="text-center mb-12" data-animate>
        <span class="font-grotesk text-xs font-600 text-sage-dark uppercase tracking-widest">Our Approach</span>
        <h2 class="font-playfair font-800 text-3xl lg:text-4xl text-charcoal mt-2">The Ascend Way for Class 9</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            step: '01',
            icon: '💡',
            title: 'Concept First',
            body: 'We begin every chapter with intuition-building — using stories, analogies, and real-world examples before touching a single formula. This ensures students truly understand, not just memorize.',
          },
          {
            step: '02',
            icon: '✏️',
            title: 'Practice Deep',
            body: 'NCERT forms the base. We layer in previous-year questions, graded problem sets, and creative application problems. Students solve a minimum of 25–30 problems per concept.',
          },
          {
            step: '03',
            icon: '📊',
            title: 'Test & Review',
            body: 'Weekly chapter tests, monthly cumulative assessments, and an end-of-term mock exam mirror the exact format of your school exams. Detailed feedback sessions follow each test.',
          },
        ].map((item, i) => (
          <div class="bg-white rounded-2xl p-7 shadow-card border border-cream-dark card-lift group" data-animate data-delay={String(i * 150)}>
            <div class="flex items-center gap-3 mb-5">
              <div class="w-12 h-12 rounded-xl bg-sage-faint flex items-center justify-center text-2xl">{item.icon}</div>
              <span class="font-grotesk text-xs font-700 text-sage-dark uppercase tracking-widest">{item.step}</span>
            </div>
            <h3 class="font-playfair font-700 text-xl text-charcoal mb-3">{item.title}</h3>
            <p class="font-dm text-sm text-charcoal-muted leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── WEEKLY SCHEDULE TEASER ── -->
  <section class="bg-charcoal py-16 lg:py-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-dot-grid bg-dot-grid opacity-5 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-10 relative z-10">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div data-animate>
          <span class="font-grotesk text-xs font-600 text-sage-light uppercase tracking-widest">Class Schedule</span>
          <h2 class="font-playfair font-800 text-3xl lg:text-4xl text-white mt-2 mb-4">Structured. Consistent. Effective.</h2>
          <p class="font-dm text-white/70 text-base leading-relaxed mb-6">
            Every week is designed with purpose — concept classes, doubt sessions, and tests balanced across the week so students are always progressing, never overwhelmed.
          </p>
          <a href="/#contact" class="inline-flex items-center gap-2 font-grotesk font-600 text-sage-light hover:text-white transition-colors text-sm">
            Ask us for your personalized schedule →
          </a>
        </div>

        <!-- Visual Timetable Placeholder -->
        <div class="bg-white/8 border border-white/15 rounded-2xl p-6" data-animate data-delay="200">
          <p class="font-grotesk text-xs font-600 text-white/50 uppercase tracking-widest mb-4">Sample Weekly Schedule</p>
          <div class="space-y-2">
            {[
              { day: 'Monday', slot: '4:00 PM – 6:00 PM', subject: 'Mathematics — Concept Class', color: 'bg-sage/30 text-sage-light' },
              { day: 'Tuesday', slot: '4:00 PM – 6:00 PM', subject: 'Science — Physics + Chemistry', color: 'bg-blue-500/20 text-blue-300' },
              { day: 'Wednesday', slot: '4:00 PM – 5:30 PM', subject: 'Mathematics — Practice & Doubt Session', color: 'bg-sage/30 text-sage-light' },
              { day: 'Thursday', slot: '4:00 PM – 6:00 PM', subject: 'Science — Biology + Lab Concepts', color: 'bg-blue-500/20 text-blue-300' },
              { day: 'Friday', slot: '4:00 PM – 6:00 PM', subject: 'Mathematics + Science — Revision', color: 'bg-amber-500/20 text-amber-300' },
              { day: 'Saturday', slot: '10:00 AM – 12:00 PM', subject: 'Weekly Test + Feedback Session', color: 'bg-red-500/20 text-red-300' },
            ].map(row => (
              <div class="flex items-start gap-3 p-2.5 rounded-lg hover:bg-white/5 transition-colors">
                <span class="font-grotesk text-xs font-600 text-white/40 w-16 flex-shrink-0 pt-0.5">{row.day.slice(0,3)}</span>
                <div class="flex-1">
                  <span class={`font-grotesk text-xs font-500 px-2 py-0.5 rounded-md ${row.color}`}>{row.subject}</span>
                  <p class="font-dm text-xs text-white/40 mt-0.5">{row.slot}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="mt-4 pt-4 border-t border-white/10 text-center">
            <p class="font-dm text-xs text-white/40">Exact timings customized per batch. Ask us for details.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHY CLASS 9 MATTERS ── -->
  <section class="bg-cream py-20 lg:py-24">
    <div class="max-w-5xl mx-auto px-6 lg:px-10 text-center">
      <div data-animate>
        <span class="font-grotesk text-xs font-600 text-sage-dark uppercase tracking-widest">The Big Picture</span>
        <h2 class="font-playfair font-800 text-3xl lg:text-5xl text-charcoal mt-2 mb-5 leading-tight">
          Why Class 9 is the <em class="text-sage-dark not-italic">most critical</em> year
        </h2>
        <p class="font-dm text-lg text-charcoal-muted leading-relaxed max-w-3xl mx-auto mb-10">
          Class 9 introduces concepts that become the bedrock of Class 10 Boards, Class 11, and ultimately JEE. A student who masters Number Systems, Triangles, Atoms, and Mechanics in Class 9 has a dramatically easier path ahead. We treat Class 9 with the same rigor as JEE preparation — because it is.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4" data-animate data-delay="200">
        {[
          { value: '40%', label: 'of JEE concepts are introduced in Class 9–10' },
          { value: '2x', label: 'faster concept absorption with our method' },
          { value: '15', label: 'maximum students per batch for focused learning' },
          { value: '52', label: 'weeks of structured learning across the year' },
        ].map(stat => (
          <div class="bg-white rounded-2xl p-5 shadow-card border border-cream-dark text-center card-lift">
            <p class="font-playfair font-800 text-3xl text-sage-dark mb-1">{stat.value}</p>
            <p class="font-dm text-xs text-charcoal-muted leading-relaxed">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <CTABanner
    heading="Ready to Build an Unbreakable Foundation?"
    subtext="Join Class 9 at Ascend Academy and start your journey to academic excellence — from the very first chapter."
    btnLabel="Enroll for Class 9"
    btnHref="/#contact"
  />
</BaseLayout>
